<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            app:title="@string/app_name"
            app:titleTextColor="@android:color/white" />

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ── Charging status card ── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Charging Status"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="?attr/colorPrimary"
                        android:paddingBottom="8dp" />

                    <TextView
                        android:id="@+id/tvChargingState"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="State: —"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:paddingBottom="4dp" />

                    <TextView
                        android:id="@+id/tvBatteryLevel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Battery: —"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:paddingBottom="4dp" />

                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/check_now_hint"
                        android:textAppearance="?attr/textAppearanceBodySmall" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Monitoring control card ── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Monitoring"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="?attr/colorPrimary"
                        android:paddingBottom="4dp" />

                    <TextView
                        android:id="@+id/tvMonitoringStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Inactive"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:paddingBottom="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnToggleMonitoring"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Start Monitoring"
                        android:layout_marginBottom="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCheckNow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Check Now"
                        style="@style/Widget.Material3.Button.OutlinedButton" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Exact Alarm Permission card ── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAlarmPermission"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/exact_alarm_permission_title"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="?attr/colorPrimary"
                        android:paddingBottom="4dp" />

                    <TextView
                        android:id="@+id/tvAlarmStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/exact_alarm_permission_subtitle"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:paddingBottom="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAlarmPermission"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/grant_exact_alarm_permission"
                        style="@style/Widget.Material3.Button.OutlinedButton" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Do-Not-Disturb card ── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Do Not Disturb Bypass"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="?attr/colorPrimary"
                        android:paddingBottom="4dp" />

                    <TextView
                        android:id="@+id/tvDndStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Checking…"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:paddingBottom="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDndPermission"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Grant DND Bypass Permission"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:visibility="gone" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
